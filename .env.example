# .env.example — nur Variablennamen/Platzhalter, KEINE echten Secrets.
# Nach .env kopieren und lokal anpassen. .env ist gitignored.

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Datenbank (Drizzle) ---
DATABASE_URL=postgres://ua_lsa:change-me-locally@localhost:5432/ua_lsa
# Repository-Backend: "mock" (Default, UI-Shell) oder "db"
REPOSITORY_BACKEND=mock
# --- Auth (Better Auth, ADR 0007) ---
BETTER_AUTH_SECRET=change-me-locally
BETTER_AUTH_URL=http://localhost:3000

# --- PostgreSQL (Docker Compose) ---
POSTGRES_USER=ua_lsa
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=ua_lsa

# --- Qdrant (Vektorsuche) ---
QDRANT_URL=http://localhost:6333

# --- Object Store (MinIO / S3-kompatibel) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-locally
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ua-lsa-dev

# --- Redis / Hintergrundjobs ---
REDIS_URL=redis://localhost:6379

# --- LLM-Provider (lokal = sicherer Default) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# --- Cloud-LLM (standardmaessig AUS; nur mit dokumentierter Schulfreigabe / CloudReleaseGrant) ---
CLOUD_LLM_ENABLED=false
# CLOUD_LLM_PROVIDER=
# CLOUD_LLM_API_KEY=
# CLOUD_LLM_REGION=
