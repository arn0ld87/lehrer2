# .env.example — nur Variablennamen/Platzhalter, KEINE echten Secrets.
# Nach .env kopieren und lokal anpassen. .env ist gitignored.

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Datenbank (Drizzle) ---
DATABASE_URL=postgres://ua_lsa:change-me-locally@localhost:5432/ua_lsa
# Repository-Backend: "mock" (Default, UI-Shell) oder "db"
REPOSITORY_BACKEND=mock
# --- Auth (Better Auth, ADR 0007) ---
BETTER_AUTH_SECRET=change-me-locally
BETTER_AUTH_URL=http://localhost:3000

# --- PostgreSQL (Docker Compose) ---
POSTGRES_USER=ua_lsa
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=ua_lsa

# --- Ollama (lokale Embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
OLLAMA_EMBEDDING_DIM=2560

# --- Qdrant (Vektorsuche) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ua_lsa_chunks

# --- Object Store (MinIO / S3-kompatibel) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-locally
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ua-lsa-dev

# --- Redis / Hintergrundjobs ---
REDIS_URL=redis://localhost:6379

# --- LLM-Provider (lokal = sicherer Default) ---
LLM_PROVIDER=ollama
# Ollama Chat-Modell fuer Unterrichtsplanung / Materialgenerierung
OLLAMA_CHAT_MODEL=qwen2.5:14b

# --- Cloud-LLM (standardmaessig AUS; nur mit dokumentierter Schulfreigabe / CloudReleaseGrant) ---
# Aktivierung erfordert CloudReleaseGrant (ADR 0002): Rechtsgrundlage, AVV, DSFA
CLOUD_LLM_ENABLED=false

# OpenAI-kompatibler Endpoint (openai.com, vLLM, llama.cpp mit OpenAI-Wrapper)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic Messages API (nur nach expliziter Schulfreigabe + DSFA; per Default OFF)
ANTHROPIC_API_KEY=
