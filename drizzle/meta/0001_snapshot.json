      "checkConstraints": {
        "confession_subject_valid": {
          "name": "confession_subject_valid",
          "value": "(\n        (\"curriculum_strand\".\"subject\" = 'RELIGION' AND \"curriculum_strand\".\"confession_context\" IN ('EVANGELISCH','KATHOLISCH','KONFESSIONSSENSIBEL_UEBERGREIFEND'))\n        OR (\"curriculum_strand\".\"subject\" = 'ETHIK' AND \"curriculum_strand\".\"confession_context\" IN ('RELIGIONSKUNDLICH','NICHT_ANWENDBAR'))\n        OR (\"curriculum_strand\".\"subject\" = 'DEUTSCH' AND \"curriculum_strand\".\"confession_context\" = 'NICHT_ANWENDBAR')\n      )"
        },
        "form_track_only_sek_i": {
          "name": "form_track_only_sek_i",
          "value": "(\"curriculum_strand\".\"school_stage\" = 'SEK_I') OR (\"curriculum_strand\".\"school_form\" IS NULL AND \"curriculum_strand\".\"education_track\" IS NULL)"
        },
        "track_requires_form": {
          "name": "track_requires_form",
          "value": "\"curriculum_strand\".\"education_track\" IS NULL OR \"curriculum_strand\".\"school_form\" IS NOT NULL"
